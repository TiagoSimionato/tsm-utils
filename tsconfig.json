{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-jsx",
    "rootDir": "./",
    "moduleResolution": "bundler",
    "paths": {
      "*": [
        "./src/*"
      ]
    },
    "allowImportingTsExtensions": false,
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "exclude": [
    "**/node_modules"
  ]
}
