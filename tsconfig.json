{
  "compilerOptions": {
    "target": "ES2020",
    "jsx": "react-jsx",
    "rootDir": "./",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "*": [
        "./src/*"
      ]
    },
    "allowImportingTsExtensions": false,
    "allowJs": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src"]
}
