  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.9.4",
    "@typescript-eslint/utils": "^8.62.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "typescript": "^5.3.3"
  }
}
