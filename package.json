{
  "name": "tsm-utils",
  "type": "module",
  "version": "0.3.4",
  "description": "Default utils functions and configs used across projects",
  "author": "Tiago Simionato",
  "license": "GPL-3.0-only",
  "repository": {
    "url": "git+https://github.com/TiagoSimionato/tsm-utils.git"
  },
  "exports": {
    ".": "./dist/src/index.js",
    "./lint": "./dist/src/lintConfig.js"
  },
  "types": "./dist/src/index.d.ts",
  "files": [
